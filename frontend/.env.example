# Optional.
# Local default is already http://localhost:3000/api, so this can stay empty.
#
# Set this only when the frontend is hosted on a different origin than the API.
# Example for production:
# VITE_API_URL=https://api.manageinsync.com/api
#
# Do not put secrets in frontend env files. VITE_ values are visible in browser.
VITE_API_URL=
