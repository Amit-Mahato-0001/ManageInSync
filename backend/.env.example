PORT=3000
NODE_ENV=development

# Core app config
# Update this for local Docker runs or your managed database host.
MONGO_URI=mongodb://localhost:27017/manageinsync

# Use the public frontend origin only. Do not include a path.
FRONTEND_URL=http://localhost:5173
# Optional extra allowed browser origins, comma-separated.
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Set true when running behind a proxy/load balancer in production.
TRUST_PROXY=true
# Request body size limit for JSON and urlencoded payloads.
JSON_BODY_LIMIT=100kb

# Auth
JWT_SECRET=replace-me-with-a-long-random-secret
ACCESS_TOKEN_SECRET=replace-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_MS=604800000
REFRESH_TOKEN_COOKIE_NAME=refreshToken
REFRESH_TOKEN_COOKIE_PATH=/api/auth
REFRESH_TOKEN_SAME_SITE=strict
# Optional shared cookie domain, for example .manageinsync.com
COOKIE_DOMAIN=

# Invite email
# Required in production because onboarding depends on invite delivery.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-gmail-app-password-without-spaces
EMAIL_FROM="ManageInSync <your-email@gmail.com>"

# Payments
# Configure both values together to enable Razorpay checkout.
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace-me
RAZORPAY_REQUEST_TIMEOUT_MS=10000

# API abuse protection
GENERAL_RATE_LIMIT_WINDOW_MS=60000
GENERAL_RATE_LIMIT_MAX=240
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=20
INVITE_RATE_LIMIT_WINDOW_MS=600000
INVITE_RATE_LIMIT_MAX=20
BILLING_RATE_LIMIT_WINDOW_MS=300000
BILLING_RATE_LIMIT_MAX=60
